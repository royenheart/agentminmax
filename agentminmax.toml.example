[server]
host = "127.0.0.1"
port = 8765

[[sources]]
id = "local-codex"
label = "Local Codex Sessions"
kind = "codex_home"
path = "$CODEX_HOME"
enabled = true
tags = ["daily", "codex"]

[[sources]]
id = "benchmark-runs"
label = "Benchmark Run Directory"
kind = "runs"
path = "runs"
enabled = true
tags = ["benchmark"]

[[sources]]
id = "codex-stream-logs"
label = "Codex Streaming Logs"
kind = "codex_logs"
path = "~/.codex/logs_2.sqlite"
enabled = false
tags = ["codex", "trace"]

[[sources]]
id = "custom-runner"
label = "Custom Benchmark Runner"
kind = "command"
command = ["python3", "experiments.py"]
enabled = false
tags = ["manual"]
